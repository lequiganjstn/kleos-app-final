<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="kleos_app_final.Views.InsightsPage"
             Title="Insights"
             BackgroundColor="#f9f9f9">

    <VerticalStackLayout Padding="20" Spacing="12">
        
        <!-- Header -->
        <Label Text="Your Insights"
               FontFamily="InstrumentSerif"
               FontSize="32"
               TextColor="#000000"
               Margin="0,16,0,0" />

        <!-- Loading -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          Color="#000000" />

        <!-- Error Message -->
        <Label Text="{Binding ErrorMessage}"
               FontFamily="Inter"
               FontSize="14"
               TextColor="#ba1a1a"
               IsVisible="{Binding HasError}"
               Margin="0,12,0,0" />

        <!-- This Week vs Last Week -->
        <Border StrokeThickness="2" StrokeShape="Rectangle" Stroke="#000000" Padding="0" Margin="0,12,0,0">
            <StackLayout Padding="20" 
                        BackgroundColor="#ffffff"
                        Spacing="8">
                <Label Text="This Week vs Last Week"
                       FontFamily="Inter"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="#7e7576" />
                <Label Text="{Binding WeekComparisonText}"
                       FontFamily="Inter"
                       FontSize="16"
                       TextColor="#000000"
                       LineBreakMode="WordWrap" />
            </StackLayout>
        </Border>

        <!-- Week Stats Cards -->
        <StackLayout Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
            
            <!-- This Week Card -->
            <Border StrokeThickness="1" StrokeShape="Rectangle" Stroke="#e2e2e2" HorizontalOptions="Fill">
                <StackLayout Padding="16" 
                            BackgroundColor="#f3f3f3"
                            Spacing="8">
                    <Label Text="This Week"
                           FontFamily="Inter"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#7e7576" />
                    <Label Text="{Binding TasksCompletedThisWeek}"
                           FontFamily="InstrumentSerif"
                           FontSize="32"
                           TextColor="#000000"
                           HorizontalTextAlignment="Center" />
                    <Label Text="tasks"
                           FontFamily="Inter"
                           FontSize="12"
                           TextColor="#7e7576"
                           HorizontalTextAlignment="Center" />
                </StackLayout>
            </Border>

            <!-- Last Week Card -->
            <Border StrokeThickness="1" StrokeShape="Rectangle" Stroke="#e2e2e2" HorizontalOptions="Fill">
                <StackLayout Padding="16" 
                            BackgroundColor="#f3f3f3"
                            Spacing="8">
                    <Label Text="Last Week"
                           FontFamily="Inter"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#7e7576" />
                    <Label Text="{Binding TasksCompletedLastWeek}"
                           FontFamily="InstrumentSerif"
                           FontSize="32"
                           TextColor="#4c4546"
                           HorizontalTextAlignment="Center" />
                    <Label Text="tasks"
                           FontFamily="Inter"
                           FontSize="12"
                           TextColor="#7e7576"
                           HorizontalTextAlignment="Center" />
                </StackLayout>
            </Border>

        </StackLayout>

        <!-- Last 7 Days Label -->
        <Label Text="Last 7 Days"
               FontFamily="Inter"
               FontSize="12"
               FontAttributes="Bold"
               TextColor="#7e7576"
               Margin="0,24,0,0" />

        <!-- Daily Breakdown -->
        <Border StrokeThickness="1" StrokeShape="Rectangle" Stroke="#e2e2e2" Padding="0">
            <StackLayout Padding="16" 
                        BackgroundColor="#ffffff"
                        Spacing="8">
                <StackLayout Orientation="Horizontal" Spacing="8" HorizontalOptions="Fill"
                             BindableLayout.ItemsSource="{Binding LastSevenDaysInsights}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <StackLayout HorizontalOptions="FillAndExpand" Spacing="4">
                                <Label Text="{Binding DayLabel}"
                                       FontFamily="Inter"
                                       FontSize="10"
                                       TextColor="#7e7576"
                                       HorizontalTextAlignment="Center" />
                                <BoxView BackgroundColor="{Binding BarColor}"
                                         HeightRequest="{Binding BarHeight}"
                                         WidthRequest="20"
                                         HorizontalOptions="Center"
                                         VerticalOptions="End" />
                                <Label Text="{Binding TasksCompleted}"
                                       FontFamily="Inter"
                                       FontSize="10"
                                       TextColor="#000000"
                                       HorizontalTextAlignment="Center" />
                            </StackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </StackLayout>
        </Border>

    </VerticalStackLayout>

</ContentPage>
