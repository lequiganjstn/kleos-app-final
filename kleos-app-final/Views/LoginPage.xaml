<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="kleos_app_final.Views.LoginPage"
             Title="Login"
             BackgroundColor="#f9f9f9">

    <VerticalStackLayout Padding="20" Spacing="12" VerticalOptions="Center">
        
        <!-- Header -->
        <Label Text="Kleos"
               FontFamily="InstrumentSerif"
               FontSize="48"
               TextColor="#000000"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,24" />
        
        <Label Text="Sign in to your account"
               FontFamily="Inter"
               FontSize="16"
               TextColor="#4c4546"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,24" />

        <!-- Email Field -->
        <Entry x:Name="EmailEntry"
               Placeholder="Email"
               Text="{Binding Email}"
               PlaceholderColor="#7e7576"
               FontFamily="Inter"
               FontSize="16"
               TextColor="#1a1c1c"
               Margin="0,8,0,8" />

        <!-- Password Field -->
        <Entry x:Name="PasswordEntry"
               Placeholder="Password"
               Text="{Binding Password}"
               IsPassword="True"
               PlaceholderColor="#7e7576"
               FontFamily="Inter"
               FontSize="16"
               TextColor="#1a1c1c"
               Margin="0,8,0,8" />

        <!-- Error Message -->
        <Label Text="{Binding ErrorMessage}"
               FontFamily="Inter"
               FontSize="14"
               TextColor="#ba1a1a"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
               Margin="0,12,0,0" />

        <!-- Login Button -->
        <Button Text="Login"
                Command="{Binding LoginCommand}"
                FontFamily="Inter"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#ffffff"
                BackgroundColor="#000000"
                CornerRadius="0"
                Padding="0,16"
                Margin="0,24,0,0" />

        <!-- Loading Indicator -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          Color="#000000"
                          Margin="0,12,0,0" />

        <!-- Link to Register -->
        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Margin="0,24,0,0">
            <Label Text="Don't have an account? "
                   FontFamily="Inter"
                   FontSize="14"
                   TextColor="#4c4546" />
            <Label Text="Register"
                   FontFamily="Inter"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#000000">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </StackLayout>

    </VerticalStackLayout>

</ContentPage>
